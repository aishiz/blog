---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CopyLink from '../components/CopyLink';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ReadingProgress from '../components/ReadingProgress';
import ScrollToTop from '../components/ScrollToTop';
import { SITE_TITLE, AUTHOR_NAME } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime?: string;
	prevPost?: { title: string; slug: string };
	nextPost?: { title: string; slug: string };
};

const { title, description, pubDate, updatedDate, heroImage, readingTime, prevPost, nextPost } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = heroImage ? new URL(heroImage.src, Astro.site).toString() : undefined;

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	"url": canonicalURL.toString(),
	...(imageURL && { "image": imageURL }),
	"datePublished": pubDate.toISOString(),
	...(updatedDate && { "dateModified": updatedDate.toISOString() }),
	"author": {
		"@type": "Person",
		"name": AUTHOR_NAME,
		"url": new URL('/about', Astro.site).toString()
	},
	"publisher": {
		"@type": "Organization",
		"name": SITE_TITLE,
		"url": Astro.site?.toString(),
		"logo": {
			"@type": "ImageObject",
			"url": new URL('/apple-touch-icon.png', Astro.site).toString()
		}
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": canonicalURL.toString()
	},
	"inLanguage": "ru-RU"
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Главная", "item": Astro.site?.toString() },
		{ "@type": "ListItem", "position": 2, "name": "Статьи", "item": new URL('/blog', Astro.site).toString() },
		{ "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL.toString() }
	]
};
---

<html lang="ru">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} image={heroImage} type="article" publishedTime={pubDate} modifiedTime={updatedDate}>
			<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
			<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		</BaseHead>
	</head>

	<body>
		<Header />
		<ReadingProgress client:load />
		<ScrollToTop client:load />
		<main>
			<div class="article-top">
				<nav class="breadcrumbs" aria-label="Навигация">
					<ol>
						<li><a href="/">Главная</a></li>
						<li><a href="/blog">Статьи</a></li>
						<li aria-current="page">{title}</li>
					</ol>
				</nav>
				<div class="article-toolbar">
					<a href="/blog" class="back-link">
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M19 12H5M12 19l-7-7 7-7" />
						</svg>
						Все статьи
					</a>
					<CopyLink client:load />
				</div>

				<header class="article-header">
					<div class="meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">&middot; обновлено <FormattedDate date={updatedDate} /></span>
						)}
						{readingTime && (
							<span class="read-time">&middot; {readingTime}</span>
						)}
					</div>
					<h1>{title}</h1>
					<p class="description">{description}</p>
				</header>

				{heroImage && (
					<div class="hero-image">
						<Image width={960} height={480} src={heroImage} alt={title} />
					</div>
				)}
			</div>

			<aside class="toc" aria-label="Содержание">
				<div class="toc-inner">
					<span class="toc-title">Содержание</span>
					<nav class="toc-nav" id="toc-nav"></nav>
				</div>
			</aside>

			<div class="article-content">
				<article>
					<div class="prose">
						<slot />
					</div>

					{(prevPost || nextPost) && (
						<nav class="post-nav">
							{prevPost ? (
								<a href={`/blog/${prevPost.slug}/`} class="nav-link nav-prev">
									<span class="nav-label">
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
										Предыдущая
									</span>
									<span class="nav-title">{prevPost.title}</span>
								</a>
							) : <div />}
							{nextPost ? (
								<a href={`/blog/${nextPost.slug}/`} class="nav-link nav-next">
									<span class="nav-label">
										Следующая
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
									</span>
									<span class="nav-title">{nextPost.title}</span>
								</a>
							) : <div />}
						</nav>
					)}
				</article>
			</div>
		</main>
		<Footer />

		<script>
			function initCodeBlocks() {
				document.querySelectorAll('pre').forEach((pre) => {
					if (pre.parentElement?.classList.contains('code-block')) return;

					const code = pre.querySelector('code');
					const dataLang = pre.getAttribute('data-language') || '';
					const classAttr = code?.getAttribute('class') || '';
					const langMatch = classAttr.match(/language-(\w+)/);
					const lang = dataLang || (langMatch ? langMatch[1] : '');

					const wrapper = document.createElement('div');
					wrapper.className = 'code-block';

					const header = document.createElement('div');
					header.className = 'code-block-header';

					const langSpan = document.createElement('span');
					langSpan.className = 'code-block-lang';
					langSpan.textContent = lang || 'code';

					const copyBtn = document.createElement('button');
					copyBtn.className = 'code-copy-btn';
					copyBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Копировать`;

					copyBtn.addEventListener('click', async () => {
						const text = pre.querySelector('code')?.textContent || pre.textContent || '';
						await navigator.clipboard.writeText(text);
						copyBtn.classList.add('copied');
						copyBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>Скопировано`;
						setTimeout(() => {
							copyBtn.classList.remove('copied');
							copyBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Копировать`;
						}, 2000);
					});

					header.appendChild(langSpan);
					header.appendChild(copyBtn);

					pre.parentNode!.insertBefore(wrapper, pre);
					wrapper.appendChild(header);
					wrapper.appendChild(pre);
				});
			}

		function initLightbox() {
			let overlay = document.getElementById('img-lightbox') as HTMLElement | null;
			if (!overlay) {
				overlay = document.createElement('div');
				overlay.id = 'img-lightbox';
				overlay.innerHTML = `
					<button class="lb-close" aria-label="Закрыть">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
					</button>
					<div class="lb-wrap"><img /><div class="lb-caption"></div></div>
				`;
				document.body.appendChild(overlay);

				const closeLb = () => {
					overlay!.classList.remove('active');
					document.body.style.overflow = '';
					const wrap = overlay!.querySelector('.lb-wrap') as HTMLElement;
					if (wrap) { wrap.style.transform = ''; wrap.style.transition = ''; }
				};

				overlay.querySelector('.lb-close')!.addEventListener('click', (e) => {
					e.stopPropagation();
					closeLb();
				});
				overlay.addEventListener('click', (e) => {
					if ((e.target as HTMLElement).closest('.lb-wrap')) return;
					closeLb();
				});

				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape' && overlay!.classList.contains('active')) closeLb();
				});

				let touchStartY = 0;
				let touchDeltaY = 0;
				const wrap = overlay.querySelector('.lb-wrap') as HTMLElement;

				wrap.addEventListener('touchstart', (e) => {
					touchStartY = e.touches[0].clientY;
					touchDeltaY = 0;
					wrap.style.transition = 'none';
				}, { passive: true });

				wrap.addEventListener('touchmove', (e) => {
					touchDeltaY = e.touches[0].clientY - touchStartY;
					const abs = Math.abs(touchDeltaY);
					const opacity = Math.max(0, 1 - abs / 300);
					wrap.style.transform = `translateY(${touchDeltaY}px) scale(${1 - abs / 1500})`;
					overlay!.style.background = `rgba(0,0,0,${0.92 * opacity})`;
				}, { passive: true });

				wrap.addEventListener('touchend', () => {
					wrap.style.transition = 'transform 0.25s ease';
					if (Math.abs(touchDeltaY) > 100) {
						wrap.style.transform = `translateY(${touchDeltaY > 0 ? '100vh' : '-100vh'}) scale(0.5)`;
						setTimeout(closeLb, 200);
					} else {
						wrap.style.transform = '';
						overlay!.style.background = '';
					}
				}, { passive: true });
			}

			const lbImg = overlay.querySelector('.lb-wrap img') as HTMLImageElement;
			const lbCaption = overlay.querySelector('.lb-caption') as HTMLElement;

			document.querySelectorAll('.prose img, .hero-image img').forEach((img) => {
				const el = img as HTMLImageElement;
				el.style.cursor = 'zoom-in';
				el.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					lbImg.src = el.src;
					lbImg.alt = el.alt;
					const alt = el.alt;
					if (alt && alt !== 'undefined' && !alt.startsWith('http')) {
						lbCaption.textContent = alt;
						lbCaption.style.display = 'block';
					} else {
						lbCaption.style.display = 'none';
					}
					overlay!.classList.add('active');
					document.body.style.overflow = 'hidden';
				});
			});
		}

		function initTOC() {
			const nav = document.getElementById('toc-nav');
			const tocEl = document.querySelector('.toc') as HTMLElement;
			if (!nav || !tocEl) return;
			nav.innerHTML = '';

			function positionTOC() {
				const mainEl = document.querySelector('main');
				if (!mainEl || !tocEl) return;
				const mainRect = mainEl.getBoundingClientRect();
				const gap = 24;
				const tocWidth = 220;
				const left = mainRect.left - tocWidth - gap;
				if (left < 8) {
					tocEl.style.display = 'none';
					return;
				}
				tocEl.style.display = '';
				tocEl.style.left = left + 'px';
			}

			positionTOC();
			window.addEventListener('resize', positionTOC);

			const prose = document.querySelector('.prose');
			if (prose) {
				const showObserver = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							tocEl.classList.add('visible');
						} else if (entry.boundingClientRect.top > 0) {
							tocEl.classList.remove('visible');
						}
					});
				}, { threshold: 0, rootMargin: '-60px 0px 0px 0px' });
				showObserver.observe(prose);
			}

			const headings = document.querySelectorAll('.prose h1, .prose h2, .prose h3');
			if (headings.length === 0) {
				const toc = document.querySelector('.toc') as HTMLElement;
				if (toc) toc.style.display = 'none';
				return;
			}

			headings.forEach((heading, i) => {
				if (!heading.id) {
					heading.id = 'heading-' + i;
				}

				const link = document.createElement('a');
				link.href = '#' + heading.id;
				link.textContent = heading.textContent || '';
				link.className = 'toc-link';

				const tag = heading.tagName.toLowerCase();
				if (tag === 'h1') link.dataset.level = '1';
				else if (tag === 'h2') link.dataset.level = '2';
				else link.dataset.level = '3';

				link.addEventListener('click', (e) => {
					e.preventDefault();
					heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
					history.replaceState(null, '', '#' + heading.id);
				});

				nav.appendChild(link);
			});

			const links = nav.querySelectorAll('.toc-link');
			const headingEls = Array.from(headings) as HTMLElement[];
			const offset = 100;

			function updateActive() {
				let current = -1;
				for (let i = 0; i < headingEls.length; i++) {
					if (headingEls[i].getBoundingClientRect().top <= offset) {
						current = i;
					} else {
						break;
					}
				}
				links.forEach(l => l.classList.remove('active'));
				if (current >= 0 && links[current]) {
					links[current].classList.add('active');
					links[current].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
				}
			}

			window.addEventListener('scroll', updateActive, { passive: true });
			updateActive();
		}

		initCodeBlocks();
		initLightbox();
		initTOC();
		document.addEventListener('astro:after-swap', () => {
			initCodeBlocks();
			initLightbox();
			initTOC();
		});
	</script>
	</body>
</html>

<style>
	main {
		position: relative;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 2rem 4rem;
	}

	.article-top {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.article-content {
		max-width: var(--max-width);
	}

	/* ---- TOC ---- */
	.toc {
		position: fixed;
		top: 80px;
		width: 220px;
		max-height: calc(100vh - 100px);
		overflow-y: auto;
		scrollbar-width: thin;
		scrollbar-color: var(--border) transparent;
		opacity: 0;
		transform: translateX(-8px);
		transition: opacity 0.4s ease, transform 0.4s ease;
		pointer-events: none;
		z-index: 10;
	}

	.toc.visible {
		opacity: 1;
		transform: translateX(0);
		pointer-events: auto;
	}

	.toc::-webkit-scrollbar {
		width: 3px;
	}

	.toc::-webkit-scrollbar-thumb {
		background: var(--border);
		border-radius: 3px;
	}

	.toc-inner {
		padding: 0.75rem 0;
	}

	.toc-title {
		display: block;
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin-bottom: 0.75rem;
		padding-left: 0.75rem;
	}

	.breadcrumbs {
		margin-top: 1.5rem;
	}

	.breadcrumbs ol {
		display: flex;
		align-items: center;
		gap: 0;
		list-style: none;
		padding: 0;
		margin: 0;
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	.breadcrumbs li {
		display: flex;
		align-items: center;
	}

	.breadcrumbs li:not(:last-child)::after {
		content: '/';
		margin: 0 0.5rem;
		color: var(--border-light);
	}

	.breadcrumbs a {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.breadcrumbs a:hover {
		color: var(--accent-light);
	}

	.breadcrumbs li[aria-current="page"] {
		color: var(--text-secondary);
		font-weight: 500;
		max-width: 300px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.article-toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin: 0.75rem 0 1.75rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.4rem 0.85rem 0.4rem 0.6rem;
		font-size: 0.85rem;
		color: var(--text-muted);
		text-decoration: none;
		border: 1px solid var(--border);
		border-radius: 100px;
		background: var(--bg-card);
		transition: all var(--transition);
	}

	.back-link:hover {
		color: var(--accent-light);
		border-color: var(--border-light);
	}

	.article-header {
		margin-bottom: 2rem;
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.82rem;
		color: var(--accent-light);
		margin-bottom: 0.75rem;
		font-weight: 500;
	}

	.updated {
		color: var(--text-muted);
		font-weight: 400;
	}

	.read-time {
		color: var(--text-muted);
		font-weight: 400;
	}

	.article-header h1 {
		font-size: 2.35rem;
		font-weight: 900;
		line-height: 1.2;
		margin-bottom: 0.75rem;
		letter-spacing: -0.02em;
	}

	.description {
		font-size: 1.12rem;
		color: var(--text-secondary);
		line-height: 1.65;
		margin: 0;
	}

	.hero-image {
		margin-bottom: 2.5rem;
		border-radius: var(--radius);
		overflow: hidden;
		border: 1px solid var(--border);
	}

	.hero-image img {
		width: 100%;
		height: auto;
		display: block;
	}

	/* ---- PROSE ---- */
	.prose {
		font-size: 1.1rem;
		line-height: 1.9;
		color: var(--text-secondary);
		letter-spacing: 0.005em;
		word-spacing: 0.02em;
	}

	.prose :global(h1) {
		font-size: 1.85rem;
		font-weight: 800;
		margin: 2.75rem 0 1rem;
		color: var(--text);
		line-height: 1.25;
	}

	.prose :global(h2) {
		font-size: 1.55rem;
		font-weight: 800;
		margin: 2.75rem 0 0.85rem;
		color: var(--text);
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border);
		line-height: 1.3;
	}

	.prose :global(h3) {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 2.25rem 0 0.7rem;
		color: var(--text);
		line-height: 1.35;
	}

	.prose :global(h4) {
		font-size: 1.1rem;
		font-weight: 700;
		margin: 1.75rem 0 0.5rem;
		color: var(--text);
	}

	.prose :global(p) {
		margin-bottom: 1.5em;
	}

	.prose :global(img) {
		border-radius: var(--radius-sm);
		border: 1px solid var(--border);
		margin: 1.75em 0;
		display: block;
	}

	.prose :global(a) {
		color: var(--accent-light);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
		text-decoration-color: rgba(255, 143, 77, 0.4);
		transition: all 0.15s ease;
	}

	.prose :global(a:hover) {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}

	.prose :global(strong) {
		color: var(--text);
		font-weight: 650;
	}

	.prose :global(em) {
		color: var(--text-secondary);
		font-style: italic;
	}

	.prose :global(.code-block) {
		margin: 1.75em 0;
	}

	.prose :global(ul), .prose :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.75em;
	}

	.prose :global(li) {
		margin-bottom: 0.5em;
		line-height: 1.8;
	}

	.prose :global(li > p) {
		margin-bottom: 0.5em;
	}

	.prose :global(blockquote) {
		margin: 1.75em 0;
		padding: 1em 1.5em;
		font-size: 1.05rem;
	}

	.prose :global(blockquote p:last-child) {
		margin-bottom: 0;
	}

	.prose :global(hr) {
		margin: 2.5em 0;
	}

	.prose :global(table) {
		margin: 1.75em 0;
		font-size: 0.95rem;
	}

	.prose :global(td) {
		color: var(--text-secondary);
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.prose { font-size: 1rem; line-height: 1.8; }
		.prose :global(h1) { font-size: 1.5rem; margin: 2rem 0 0.75rem; }
		.prose :global(h2) { font-size: 1.3rem; margin: 2rem 0 0.7rem; }
		.prose :global(h3) { font-size: 1.1rem; margin: 1.75rem 0 0.6rem; }
		.prose :global(img) { margin: 1.25em 0; border-radius: 8px; }
		.prose :global(blockquote) { padding: 0.75em 1em; font-size: 0.95rem; }
		.prose :global(ul), .prose :global(ol) { padding-left: 1.35em; }
	}

	@media (max-width: 480px) {
		.prose { font-size: 0.95rem; line-height: 1.75; }
		.prose :global(h1) { font-size: 1.35rem; }
		.prose :global(h2) { font-size: 1.2rem; }
		.prose :global(h3) { font-size: 1.05rem; }
		.prose :global(p) { margin-bottom: 1.25em; }
		.prose :global(img) {
			margin: 1em -1rem;
			width: calc(100% + 2rem);
			max-width: calc(100% + 2rem);
			border-radius: 0;
