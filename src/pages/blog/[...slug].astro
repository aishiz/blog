---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog'))
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

	return posts.map((post, i) => ({
		params: { slug: post.id },
		props: {
			post,
			prevPost: posts[i + 1] ?? null,
			nextPost: posts[i - 1] ?? null,
		},
	}));
}

interface Props {
	post: CollectionEntry<'blog'>;
	prevPost: CollectionEntry<'blog'> | null;
	nextPost: CollectionEntry<'blog'> | null;
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const words = (post.body ?? '').trim().split(/\s+/).length;
const readingTime = `${Math.max(1, Math.round(words / 200))} мин чтения`;
---

<BlogPost
	{...post.data}
	readingTime={readingTime}
	prevPost={prevPost ? { title: prevPost.data.title, slug: prevPost.id } : undefined}
	nextPost={nextPost ? { title: nextPost.data.title, slug: nextPost.id } : undefined}
>
	<Content />
</BlogPost>
