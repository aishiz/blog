---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ScrollToTop from '../../components/ScrollToTop';
import SearchBar from '../../components/SearchBar';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function estimateReadingTime(body: string) {
	const words = body.trim().split(/\s+/).length;
	const minutes = Math.max(1, Math.round(words / 200));
	return `${minutes} мин`;
}

function formatDate(d: Date) {
	return d.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' });
}

const searchData = posts.map((post) => ({
	title: post.data.title,
	description: post.data.description,
	slug: post.id,
	date: formatDate(post.data.pubDate),
}));

const CATEGORIES = [
	{ key: 'фундамент', varName: '--cat-fundament' },
	{ key: 'тулы', varName: '--cat-tools' },
	{ key: 'модели', varName: '--cat-models' },
	{ key: 'хайп', varName: '--cat-hype' },
].map((c) => ({ ...c, count: posts.filter((p) => p.data.category === c.key).length }));

const collectionSchema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": `Все статьи — ${SITE_TITLE}`,
	"description": "Статьи об AI-агентах, LLM, квантизации моделей и ML Inference",
	"url": new URL('/blog', Astro.site).toString(),
	"isPartOf": {
		"@type": "WebSite",
		"name": SITE_TITLE,
		"url": Astro.site?.toString()
	},
	"breadcrumb": {
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Главная", "item": Astro.site?.toString() },
			{ "@type": "ListItem", "position": 2, "name": "Статьи", "item": new URL('/blog', Astro.site).toString() }
		]
	}
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={`Все статьи — ${SITE_TITLE}`} description="Статьи об AI-агентах, LLM, квантизации моделей, ML Inference и практическом опыте работы с большими языковыми моделями.">
			<script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
		</BaseHead>
	</head>
	<body>
		<Header />
		<ScrollToTop client:load />
		<main>
			<div class="page-header">
				<div class="page-title-row">
					<h1>Все статьи</h1>
					<span class="count">{posts.length}</span>
				</div>
				<p>Мои мысли, заметки и статьи на разные темы</p>
				<SearchBar client:load posts={searchData} />
				<div class="filter-row" role="group" aria-label="Фильтр по рубрикам">
					<button class="filter-chip active" data-cat="">Все <span class="chip-count">{posts.length}</span></button>
					{CATEGORIES.map((c) => (
						<button class="filter-chip" data-cat={c.key} style={`--chip: var(${c.varName})`}>
							{c.key} <span class="chip-count">{c.count}</span>
						</button>
					))}
				</div>
			</div>

			<div class="posts-grid">
				{posts.map((post, i) => (
					<div class:list={['card-wrap', { 'wrap-featured': i === 0 }]} data-category={post.data.category ?? ''}>
						<BlogCard
							title={post.data.title}
							description={post.data.description}
							date={formatDate(post.data.pubDate)}
							slug={post.id}
							heroImage={post.data.heroImage?.src}
							readingTime={estimateReadingTime(post.body ?? '')}
							category={post.data.category}
							featured={i === 0}
						/>
					</div>
				))}
			</div>

			<script>
				const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
				const wraps = document.querySelectorAll<HTMLElement>('.card-wrap');
				chips.forEach((chip) => {
					chip.addEventListener('click', () => {
						chips.forEach((c) => c.classList.remove('active'));
						chip.classList.add('active');
						const cat = chip.dataset.cat ?? '';
						wraps.forEach((w) => {
							w.style.display = !cat || w.dataset.category === cat ? '' : 'none';
						});
					});
				});
			</script>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: var(--max-width-wide);
		margin: 0 auto;
		padding: 0 2rem 4rem;
	}

	.page-header {
		padding: 3rem 0 2rem;
	}

	.page-title-row {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.4rem;
	}

	.page-title-row h1 {
		font-size: 2rem;
		font-weight: 800;
	}

	.count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 28px;
		height: 28px;
		padding: 0 8px;
		border-radius: 100px;
		background: var(--accent-glow);
		border: 1px solid rgba(255, 107, 43, 0.25);
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--accent-light);
	}

	.page-header p {
		color: var(--text-secondary);
		font-size: 1rem;
		margin-bottom: 1.25rem;
	}

	.filter-row {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-top: 1rem;
	}

	.filter-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.35rem 0.85rem;
		border-radius: 100px;
		border: 1px solid var(--border);
		background: var(--bg-card);
		color: var(--text-secondary);
		font-size: 0.8rem;
		font-weight: 600;
		cursor: pointer;
		font-family: inherit;
		transition: all 0.2s ease;
		--chip: var(--accent);
	}

	.filter-chip:hover {
		border-color: color-mix(in srgb, var(--chip) 60%, transparent);
		color: var(--text);
	}

	.filter-chip.active {
		border-color: var(--chip);
		background: color-mix(in srgb, var(--chip) 14%, var(--bg-card));
		color: var(--chip);
	}

	.chip-count {
		font-size: 0.7rem;
		font-weight: 700;
		opacity: 0.65;
		font-variant-numeric: tabular-nums;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
	}

	.card-wrap {
		display: grid;
	}

	.wrap-featured {
		grid-column: 1 / -1;
	}

	@media (max-width: 768px) {
		main { padding: 0 1.25rem 3rem; }
		.page-header { padding: 2rem 0 1.5rem; }
		.posts-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 480px) {
		main { padding: 0 1rem 2.5rem; }
		.page-header { padding: 1.5rem 0 1.25rem; }
		.page-title-row h1 { font-size: 1.6rem; }
		.page-header p { font-size: 0.9rem; margin-bottom: 1rem; }
		.posts-grid { gap: 1rem; }
	}
</style>
