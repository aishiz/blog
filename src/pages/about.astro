---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ScrollToTop from '../components/ScrollToTop';
import { SITE_TITLE } from '../consts';
import aboutPhoto from '../assets/photo_2026-02-11_16-07-52.jpg';

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Артемий",
	"url": new URL('/about', Astro.site).toString(),
	"image": new URL(aboutPhoto.src, Astro.site).toString(),
	"jobTitle": "AI/ML Engineer, Team Lead",
	"description": "AI-инженер, автор блога ЭЙ АЙ ШИЗ. Специализируюсь на AI-агентах, LLM, ML Inference и квантизации моделей.",
	"alumniOf": {
		"@type": "EducationalOrganization",
		"name": "МАИ (Московский авиационный институт)"
	},
	"knowsAbout": ["AI Agents", "LLM", "ML Inference", "vLLM", "Quantization", "RAG", "Foundation Models"],
	"sameAs": ["https://t.me/ai_shizz"]
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Главная", "item": Astro.site?.toString() },
		{ "@type": "ListItem", "position": 2, "name": "Обо мне", "item": new URL('/about', Astro.site).toString() }
	]
};
---

<html lang="ru">
	<head>
		<BaseHead title={`Обо мне — ${SITE_TITLE}`} description="Артемий — AI-инженер, автор блога ЭЙ АЙ ШИЗ. 6+ лет в индустрии, специализация на AI-агентах, LLM, ML Inference и квантизации моделей.">
			<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
			<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		</BaseHead>
	</head>

	<body>
		<Header />
		<ScrollToTop client:load />
		<main>
			<section class="about-hero" aria-label="Обо мне">
				<div class="about-photo">
					<Image src={aboutPhoto} alt="Артемий" width={280} height={420} />
				</div>
				<div class="about-intro">
					<span class="label">Обо мне</span>
					<h1>Меня зовут Артемий, и&nbsp;у&nbsp;вас начнётся <span class="highlight">ШИЗА</span></h1>
					<p class="lead">
						AI&#8209;Agents, Foundation&nbsp;Models, ML&nbsp;Inference, Managed&nbsp;RAG&nbsp;—
						всё это моё. Я сам руками поднимал LLM бессонными ночами.
					</p>
					<div class="about-actions">
						<a href="/blog" class="cta-button">
							Читать блог
							<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
						</a>
						<div class="social-links">
							<a href="https://t.me/ai_shizz" target="_blank" rel="noopener" class="social-link" title="Telegram канал">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
							</a>
						</div>
					</div>
				</div>
			</section>

			<section class="stats">
				<div class="stat-card accent">
					<span class="stat-value">6+</span>
					<span class="stat-label">Лет в индустрии</span>
				</div>
				<div class="stat-card">
					<span class="stat-value">0</span>
					<span class="stat-label">Отпусков за 6 лет</span>
				</div>
				<div class="stat-card">
					<span class="stat-value">DS &rarr; Lead</span>
					<span class="stat-label">За 2 года</span>
				</div>
				<div class="stat-card">
					<span class="stat-value">МАИ</span>
					<span class="stat-label">Образование</span>
				</div>
			</section>

			<section class="bio">
				<h2>Кто я такой?</h2>
				<p>
					Закончил <strong>МАИ</strong> по специальности «Системы управления летательным аппаратом».
					Потом ушёл в аспирантуру по прикладной математике — пишу диссертацию на тему
					<em>«Применение методов машинного обучения в системах управления летательными аппаратами»</em>.
					Аспирантуру закончил, диссертацию пока не защитил — в процессе. Там же веду пары.
				</p>
			</section>

			<section class="life-section">
				<h2>Кто я по жизни?</h2>
				<div class="life-list">
					<div class="life-item">
						<div class="life-marker"></div>
						<div class="life-content">
							<p>По жизни я — <strong>ШИЗ</strong>: работать 24/7, «подбирать» vLLM аргументами для запуска, чтобы получить +5% производительности — это про меня. По ночам сижу в issue репозитория vLLM и достаю китайцев тупыми вопросами.</p>
						</div>
					</div>
					<div class="life-item">
						<div class="life-marker fire"></div>
						<div class="life-content">
							<p>Если не работал с 9 до 4 утра, значит, не работал вовсе.</p>
							<blockquote>Живи, вкалывай, вкалывай, вкалывай, сдохни!</blockquote>
						</div>
					</div>
					<div class="life-item">
						<div class="life-marker"></div>
						<div class="life-content">
							<p>За <strong>6 лет</strong> работы ни разу не был в отпуске. Брал отпуск и работал дальше.</p>
						</div>
					</div>
					<div class="life-item">
						<div class="life-marker"></div>
						<div class="life-content">
							<p>Создаю агентов чисто <strong>по фану</strong>, а потом их в прод запускают.</p>
						</div>
					</div>
					<div class="life-item">
						<div class="life-marker"></div>
						<div class="life-content">
							<p>Лютый гавнокодер, поэтому, когда вышел <strong>Cursor</strong>, стал его фанатом. Имею 10+ «гавно-вайбкодерских IDE».</p>
						</div>
					</div>
					<div class="life-item">
						<div class="life-marker fun"></div>
						<div class="life-content">
							<p>Мой принцип — <strong>Just For Fun</strong>. Половина фичей в продуктах была придумана в баре и иногда во время ночной шизы. Сел делать — и пока не сделаю, не иду спать.</p>
						</div>
					</div>
				</div>
			</section>

			<section class="achievements-section">
				<h2>Чего добился?</h2>
				<div class="achievements-grid">
					<div class="ach-card">
						<span class="ach-num">01</span>
						<p>Создал «тряску» в Yandex Cloud</p>
					</div>
					<div class="ach-card">
						<span class="ach-num">02</span>
						<p>Сделал LLM доступнее в РФ</p>
					</div>
					<div class="ach-card">
						<span class="ach-num">03</span>
						<p>За 2 года от DS до лидера AI&#8209;продуктов</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: var(--max-width-wide);
		margin: 0 auto;
		padding: 0 2rem 4rem;
	}

	/* ---- HERO ---- */
	.about-hero {
		display: flex;
		flex-direction: row !important;
		align-items: flex-start;
		gap: 3rem;
		padding: 3.5rem 0 2.5rem;
	}

	.about-photo { flex-shrink: 0; }

	.about-photo img {
		width: 260px;
		height: auto;
		border-radius: 20px;
		object-fit: cover;
		border: 2px solid var(--border-light);
	}

	.about-intro {
		flex: 1;
		min-width: 0;
		padding-top: 0.25rem;
	}

	.label {
		display: inline-block;
		padding: 0.25rem 0.8rem;
		background: var(--accent-glow);
		border: 1px solid rgba(255, 107, 43, 0.25);
		border-radius: 100px;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--accent-light);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin-bottom: 0.85rem;
	}

	.about-intro h1 {
		font-size: 2rem;
		font-weight: 800;
		line-height: 1.25;
		margin-bottom: 1rem;
	}

	.highlight {
		background: linear-gradient(135deg, var(--accent), var(--accent-yellow));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.lead {
		font-size: 1rem;
		color: var(--text-secondary);
		line-height: 1.75;
		margin-bottom: 1.5rem !important;
	}

	.about-actions {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.65rem 1.5rem;
		background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
		color: white;
		border-radius: 100px;
		font-weight: 700;
		font-size: 0.88rem;
		text-decoration: none;
		transition: all 0.2s ease;
		box-shadow: 0 4px 20px rgba(255, 107, 43, 0.2);
		flex-shrink: 0;
	}

	.cta-button:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 28px rgba(255, 107, 43, 0.3);
		color: white;
	}

	.social-links { display: flex; gap: 0.5rem; }

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 50%;
		border: 1px solid var(--border);
		background: var(--bg-card);
		color: var(--text-muted);
		transition: all 0.2s ease;
	}

	.social-link:hover {
		color: var(--accent-light);
		border-color: var(--accent);
		background: var(--bg-card-hover);
		transform: translateY(-2px);
	}

	/* ---- STATS ---- */
	.stats {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
		padding-bottom: 3rem;
	}

	.stat-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.3rem;
		padding: 1.25rem 0.75rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		text-align: center;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	.stat-card:hover {
		border-color: var(--border-light);
		transform: translateY(-2px);
	}

	.stat-card.accent {
		border-color: rgba(255, 107, 43, 0.3);
		background: linear-gradient(135deg, rgba(255, 107, 43, 0.06), rgba(201, 70, 255, 0.04));
	}

	.stat-value {
		font-size: 1.35rem;
		font-weight: 800;
		color: var(--text);
	}

	.stat-label {
		font-size: 0.75rem;
		color: var(--text-muted);
		font-weight: 500;
	}

	/* ---- BIO ---- */
	.bio {
		padding-bottom: 3rem;
	}

	.bio h2 {
		font-size: 1.35rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}

	.bio p {
		font-size: 1rem;
		color: var(--text-secondary);
		line-height: 1.85;
		max-width: var(--max-width);
	}

	.bio strong {
		color: var(--text);
	}

	.bio em {
		color: var(--accent-light);
		font-style: normal;
	}

	/* ---- LIFE TIMELINE ---- */
	.life-section {
		padding-bottom: 3rem;
	}

	.life-section h2 {
		font-size: 1.35rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
	}

	.life-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		padding-left: 1.5rem;
		border-left: 2px solid var(--border);
	}

	.life-item {
		display: flex;
		align-items: flex-start;
		gap: 1.25rem;
		padding: 1rem 0;
		position: relative;
	}

	.life-item + .life-item {
		border-top: 1px solid var(--border);
	}

	.life-marker {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--border-light);
		flex-shrink: 0;
		margin-top: 0.45rem;
		position: relative;
		left: -1.85rem;
		margin-right: -0.6rem;
		transition: background 0.2s ease;
	}

	.life-item:hover .life-marker {
		background: var(--accent);
	}

	.life-marker.fire {
		background: var(--accent);
		box-shadow: 0 0 8px rgba(255, 107, 43, 0.4);
	}

	.life-marker.fun {
		background: var(--accent-yellow);
		box-shadow: 0 0 8px rgba(255, 217, 61, 0.3);
	}

	.life-content {
		flex: 1;
		min-width: 0;
	}

	.life-content p {
		font-size: 0.95rem;
		color: var(--text-secondary);
		line-height: 1.7;
		margin: 0;
	}

	.life-content strong {
		color: var(--text);
	}

	.life-content blockquote {
		margin: 0.6rem 0 0;
		padding: 0.6rem 1rem;
		border-left: 3px solid var(--accent);
		background: var(--accent-glow);
		border-radius: 0 8px 8px 0;
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--text);
		font-style: normal;
	}

	/* ---- ACHIEVEMENTS ---- */
	.achievements-section {
		padding-bottom: 2rem;
	}

	.achievements-section h2 {
		font-size: 1.35rem;
		font-weight: 800;
		margin-bottom: 1.25rem;
	}

	.achievements-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.ach-card {
		padding: 1.5rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	.ach-card:hover {
		border-color: var(--accent);
		transform: translateY(-3px);
	}

	.ach-num {
		display: block;
		font-size: 2rem;
		font-weight: 900;
		line-height: 1;
		margin-bottom: 0.75rem;
		background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		opacity: 0.7;
	}

	.ach-card p {
		font-size: 0.95rem;
		color: var(--text);
		font-weight: 600;
		line-height: 1.45;
		margin: 0;
	}

	/* ---- RESPONSIVE ---- */
	@media (max-width: 550px) {
		main { padding: 0 1rem 3rem; }

		.about-hero {
			flex-direction: column !important;
			align-items: center;
			text-align: center;
			gap: 1.5rem;
			padding: 2rem 0 2rem;
		}

		.about-photo img { width: 180px; border-radius: 16px; }
		.about-intro { padding-top: 0; }
		.about-intro h1 { font-size: 1.5rem; }
		.about-actions { flex-direction: column; gap: 0.75rem; }
		.social-links { justify-content: center; }
		.stats { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
		.achievements-grid { grid-template-columns: 1fr; }
		.life-list { padding-left: 1.25rem; }
		.life-item { gap: 1rem; }
	}

	@media (max-width: 400px) {
		.about-hero { padding: 1.5rem 0; gap: 1.25rem; }
		.about-photo img { width: 150px; border-radius: 14px; }
		.about-intro h1 { font-size: 1.35rem; }
		.lead { font-size: 0.92rem !important; }
		.stat-card { padding: 1rem 0.5rem; }
		.stat-value { font-size: 1.15rem; }
		.stat-label { font-size: 0.7rem; }
		.bio h2, .life-section h2, .achievements-section h2 { font-size: 1.2rem; }
		.bio p { font-size: 0.92rem; }
		.life-content p { font-size: 0.88rem; }
		.life-content blockquote { font-size: 0.85rem; padding: 0.5rem 0.85rem; }
		.ach-card { padding: 1.15rem; }
		.ach-num { font-size: 1.6rem; }
		.ach-card p { font-size: 0.88rem; }
	}

	@media (min-width: 551px) and (max-width: 768px) {
		.about-hero { gap: 2rem; }
		.about-photo img { width: 200px; border-radius: 18px; }
		.about-intro h1 { font-size: 1.7rem; }
		.stats { grid-template-columns: repeat(2, 1fr); }
		.achievements-grid { grid-template-columns: 1fr; }
	}
</style>
