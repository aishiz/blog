---
interface Props {
	title: string;
	description: string;
	date: string;
	slug: string;
	heroImage?: string;
	readingTime?: string;
	featured?: boolean;
}

const { title, description, date, slug, heroImage, readingTime, featured = false } = Astro.props;
---

<a href={`/blog/${slug}/`} class:list={['card', { featured }]}>
	{heroImage && (
		<div class="card-image">
			<img src={heroImage} alt={title} loading="lazy" />
			{featured && <span class="featured-badge">Новое</span>}
		</div>
	)}
	<div class="card-body">
		<div class="card-meta">
			<time>{date}</time>
			{readingTime && <span class="reading-time">{readingTime}</span>}
		</div>
		<h3>{title}</h3>
		<p>{description}</p>
		<span class="card-link">
			Читать далее
			<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
				<path d="M5 12h14M12 5l7 7-7 7" />
			</svg>
		</span>
	</div>
</a>

<style>
	.card {
		display: block;
		position: relative;
		background: var(--bg-card);
		border-radius: var(--radius);
		border: 1px solid var(--border);
		overflow: hidden;
		text-decoration: none;
		transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
	}

	.card::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 3px;
		background: linear-gradient(180deg, var(--accent), var(--accent-secondary));
		border-radius: 3px 0 0 3px;
		opacity: 0;
		transition: opacity 0.25s ease;
		z-index: 2;
	}

	.card:hover::before {
		opacity: 1;
	}

	.card:hover {
		transform: translateY(-4px);
		border-color: var(--border-light);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
	}

	.card-image {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16/9;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.card:hover .card-image img {
		transform: scale(1.04);
	}

	.featured-badge {
		position: absolute;
		top: 12px;
		left: 12px;
		padding: 0.2rem 0.65rem;
		background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
		color: white;
		font-size: 0.7rem;
		font-weight: 700;
		border-radius: 100px;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
		z-index: 2;
	}

	.card-body {
		padding: 1.1rem 1.3rem 1.3rem;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.5rem;
	}

	.card-meta time {
		font-size: 0.73rem;
		color: var(--accent-light);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.reading-time {
		font-size: 0.72rem;
		color: var(--text-muted);
		padding-left: 0.75rem;
		border-left: 1px solid var(--border);
	}

	.card h3 {
		font-size: 1.05rem;
		color: var(--text);
		line-height: 1.35;
		font-weight: 700;
		margin-bottom: 0.35rem;
		transition: color 0.2s ease;
	}

	.card:hover h3 {
		color: var(--accent-light);
	}

	.card p {
		margin: 0;
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		margin-top: 0.8rem;
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--accent-light);
		transition: gap 0.2s ease, color 0.2s ease;
	}

	.card:hover .card-link {
		gap: 0.55rem;
		color: var(--accent);
	}

	/* ---- FEATURED (full width) ---- */
	.featured {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: 1.1fr 1fr;
	}

	.featured .card-image {
		aspect-ratio: auto;
		min-height: 260px;
	}

	.featured .card-body {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 1.75rem 2rem;
	}

	.featured h3 {
		font-size: 1.4rem;
		margin-bottom: 0.5rem;
	}

	.featured p {
		-webkit-line-clamp: 3;
		font-size: 0.92rem;
	}

	@media (max-width: 650px) {
		.featured {
			grid-template-columns: 1fr;
		}

		.featured .card-image {
			aspect-ratio: 16/9;
			min-height: auto;
		}

		.featured .card-body {
			padding: 1.1rem 1.3rem 1.3rem;
		}

		.featured h3 {
			font-size: 1.1rem;
		}
	}
</style>
