---
---

<button class="theme-toggle" aria-label="Переключить тему" title="Переключить тему">
	<svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<circle cx="12" cy="12" r="5" />
		<line x1="12" y1="1" x2="12" y2="3" />
		<line x1="12" y1="21" x2="12" y2="23" />
		<line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
		<line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
		<line x1="1" y1="12" x2="3" y2="12" />
		<line x1="21" y1="12" x2="23" y2="12" />
		<line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
		<line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
	</svg>
	<svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
	</svg>
	<svg class="icon-system" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
		<line x1="8" y1="21" x2="16" y2="21" />
		<line x1="12" y1="17" x2="12" y2="21" />
	</svg>
</button>

<style>
	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		background: none;
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--text-muted);
		cursor: pointer;
		transition: all 0.2s ease;
		flex-shrink: 0;
	}

	.theme-toggle:hover {
		color: var(--text);
		border-color: var(--border-light);
		background: var(--bg-card);
	}

	.icon-sun, .icon-moon, .icon-system {
		display: none;
	}

	:global([data-theme-pref="light"]) .icon-sun {
		display: block;
	}

	:global([data-theme-pref="dark"]) .icon-moon {
		display: block;
	}

	:global([data-theme-pref="system"]) .icon-system {
		display: block;
	}
</style>

<script>
	function resolveTheme(pref: string): string {
		if (pref === 'system') {
			return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
		}
		return pref;
	}

	function applyTheme(pref: string) {
		const resolved = resolveTheme(pref);
		document.documentElement.setAttribute('data-theme', resolved);
		document.documentElement.setAttribute('data-theme-pref', pref);
		localStorage.setItem('theme-pref', pref);
	}

	function initThemeToggle() {
		const btn = document.querySelector('.theme-toggle');
		btn?.addEventListener('click', () => {
			const current = document.documentElement.getAttribute('data-theme-pref') || 'system';
			const order = ['system', 'light', 'dark'];
			const idx = order.indexOf(current);
			const next = order[(idx + 1) % order.length];
			applyTheme(next);
		});

		const mq = window.matchMedia('(prefers-color-scheme: light)');
		mq.addEventListener('change', () => {
			const pref = document.documentElement.getAttribute('data-theme-pref') || 'system';
			if (pref === 'system') {
				applyTheme('system');
			}
		});
	}

	initThemeToggle();
	document.addEventListener('astro:after-swap', initThemeToggle);
</script>
